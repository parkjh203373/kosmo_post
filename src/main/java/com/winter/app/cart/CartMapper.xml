<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.winter.app.cart.CartMapper">
  	
	<insert id="create" parameterType="CartDTO">
		INSERT INTO "TB_CART" VALUES (#{username}, #{productNum})
	</insert>
	
	<select id="list" parameterType="CartDTO" resultMap="CartListResult">
		SELECT P.*, F.*
    	FROM "TB_CART" C
    		LEFT JOIN "TB_PRODUCT" P
    		USING ("PRODUCT_NUM")
    			LEFT JOIN "TB_PRODUCTFILE" F
    			USING ("PRODUCT_NUM")
    	WHERE "USERNAME" = #{username}
	</select>
	
	<resultMap type="CartDTO" id="CartListResult">
    	<id column="USERNAME" property="username"/>
    	<id column="PRODUCT_NUM" property="productNum"/>
    	<association property="productDTO" javaType="ProductDTO">
    	    <result column="PRODUCT_NAME" property="productName"/>
    	    <result column="PRODUCT_RATE" property="productRate"/>
    	    <result column="PRODUCT_TYPE" property="productType"/>
    	    <association property="productFileDTO" javaType="ProductFileDTO">
				<id column="FILE_NUM" property="fileNum"/>
				<result column="FILE_NAME" property="fileName"/>
				<result column="ORI_NAME" property="oriName"/>
			</association>
    	</association>
	</resultMap>

</mapper>